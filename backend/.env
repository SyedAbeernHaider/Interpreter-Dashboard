# Backend Environment Configuration
# 
# The DB_HOST below should be the PUBLIC IP or hostname of your hosting server
# (NOT 127.0.0.1 - that only works when running on the server itself)
#
# Example: DB_HOST=staging.connecthear.org  OR  DB_HOST=123.456.789.0
#
# IMPORTANT: Your hosting provider may also need to whitelist your IP for MySQL access.
# In cPanel → Remote MySQL, add your local IP address.

PORT=3001

DB_HOST=app.connecthear.org
DB_PORT=3306
DB_USER=connect7hear8org6_connect7hear8user
DB_PASS=Abcd!234Abcd!234
DB_NAME=connect7hear8org6_hear
 